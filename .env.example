# Schwab API (get from developer.schwab.com)
SCHWAB_APP_KEY=your_app_key_here
SCHWAB_APP_SECRET=your_app_secret_here
SCHWAB_CALLBACK_URL=https://127.0.0.1

# Discord (get from discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# Anthropic (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Screener thresholds
MIN_DIVIDEND_YIELD=0.02
MAX_PE_RATIO=25.0
MIN_EARNINGS_GROWTH=0.05
MAX_RSI=70.0

# Trade sizing
MAX_POSITION_SIZE_USD=500.0

# Scheduler (24-hour format)
SCAN_HOUR=9
SCAN_MINUTE=0

# Safety flags — set to false only when ready for live trading
DRY_RUN=true
PAPER_TRADING=true

# Database
DB_PATH=algo_trade.db
