# Schwab API (required — get from developer.schwab.com)
SCHWAB_APP_KEY=your_app_key_here
SCHWAB_APP_SECRET=your_app_secret_here
SCHWAB_CALLBACK_URL=https://127.0.0.1        # must match the redirect URI registered at developer.schwab.com
SCHWAB_ACCOUNT_HASH=your_account_hash_here

# Discord (required — get from discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here      # right-click channel → Copy Channel ID (Developer Mode must be on)

# Analyst provider — choose one of two paths:
#
# Path A — Claude only (legacy): set ANTHROPIC_API_KEY; leave ANALYST_* lines blank or omit them.
ANTHROPIC_API_KEY=your_anthropic_key_here    # optional if using Path B
#
# Path B — multi-provider: set ANALYST_PROVIDER + ANALYST_API_KEY; ANTHROPIC_API_KEY not required.
ANALYST_PROVIDER=claude                      # claude | gemini | openai | github  (default: claude)
ANALYST_API_KEY=                             # required for gemini/openai/github; optional when ANALYST_PROVIDER=claude
ANALYST_MODEL=                               # optional — e.g. gemini-2.5-flash for Gemini free tier
#
# Optional fallback analyst — used when the primary fails (quota exhausted, rate limit, etc.)
# Recommended: GitHub Models (free GPT-4o-mini, 128k context; requires a GitHub PAT with models:read scope)
# ANALYST_FALLBACK_PROVIDER=github
# ANALYST_FALLBACK_API_KEY=your_github_pat
# ANALYST_FALLBACK_MODEL=                   # optional — defaults to gpt-4o-mini for github provider

# Screener thresholds (optional — shown with defaults)
MIN_DIVIDEND_YIELD=0.02
MAX_PE_RATIO=25.0
MIN_EARNINGS_GROWTH=0.05
MAX_RSI=70.0
SELL_RSI_THRESHOLD=70.0                      # RSI above this on an open position triggers sell analysis (per D-02)
MIN_VOLUME_RATIO=0.5                         # current day volume / 20-day avg must meet or exceed this
SELL_RSI_THRESHOLD=70.0                      # RSI above this on an open position triggers sell analysis (per D-02)
ANALYST_DAILY_LIMIT=18                       # Max analyst API calls per day across buy+sell passes (per D-11; Gemini free tier = 20 RPD)

# Trade sizing (optional)
MAX_POSITION_SIZE_USD=500.0          # max USD spent per individual trade
MAX_PORTFOLIO_USD=20000.0            # total portfolio exposure ceiling; Approve is blocked if adding this trade would exceed it

# Scheduler — single daily scan (optional; 24-hour format)
SCAN_HOUR=9
SCAN_MINUTE=0
# SCAN_TIMES=09:00,13:00                     # optional: comma-separated HH:MM overrides SCAN_HOUR/SCAN_MINUTE
ETF_SCAN_HOUR=9                              # ETF scan hour (24-hour format); defaults to 09 (per Phase 12 D-01)
ETF_SCAN_MINUTE=30                           # ETF scan minute; defaults to 30 (30-minute offset from stock scan to avoid yfinance rate-limit contention)

# S&P 500 universe (optional)
TOP_SP500_COUNT=10                           # top N S&P 500 tickers by EPS+ROE score added to each scan
ANALYST_CALL_DELAY_S=12.0                    # seconds between analyst API calls (enforces <=5 RPM on free tier)

# Safety flags (optional — set to false only when ready for live trading)
DRY_RUN=true                                 # when true, Approve button logs the order instead of placing it
PAPER_TRADING=true                           # when true, Schwab paper trading endpoint is used

# News provider (optional — free tier: 25 requests/day; get key at alphavantage.co)
# When set, Alpha Vantage NEWS_SENTIMENT is used instead of yfinance for headlines.
# Each headline includes a pre-scored sentiment label, e.g. "Fed cuts rates [Bullish, 0.72]"
# ALPHA_VANTAGE_API_KEY=your_key_here

# Logging (optional)
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR

# Database (optional)
DB_PATH=algo_trade.db
